# CyberDash Docker environment template
# Copy this file to .env.docker and fill in your values.
# Never commit real secrets to git.

# ── Required for full production use ──────────────────────────────────────────
JWT_SECRET=replace-with-a-secure-random-secret

# ── Optional: enables Engagement Dashboard & Workflow features ─────────────────
# DATABASE_URL=mysql://cyberdash:cyberdash@db:3306/cyberdash

# ── Optional: OAuth provider ──────────────────────────────────────────────────
# OAUTH_SERVER_URL=https://your-oauth-server.example.com
# OWNER_OPEN_ID=your-owner-openid

# ── Optional: AI integration (Anthropic/Forge API) ────────────────────────────
# BUILT_IN_FORGE_API_URL=https://api.anthropic.com
# BUILT_IN_FORGE_API_KEY=your-api-key
